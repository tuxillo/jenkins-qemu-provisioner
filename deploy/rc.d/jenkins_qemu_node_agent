#!/bin/sh
# PROVIDE: jenkins_qemu_node_agent
# REQUIRE: NETWORKING
# KEYWORD: shutdown

. /etc/rc.subr

name="jenkins_qemu_node_agent"
rcvar=jenkins_qemu_node_agent_enable

load_rc_config $name
: ${jenkins_qemu_node_agent_enable:=NO}
: ${jenkins_qemu_node_agent_logfile:=/var/log/jenkins-qemu-node-agent.log}

command="/usr/sbin/daemon"
procname="/usr/sbin/daemon"
app_command="/opt/jenkins-qemu-node-agent/venv/bin/python"
app_args="-m node_agent.main"
service_user="jenkins-qemu-agent"
rundir="/var/run/${name}"
pidfile="${rundir}/${name}.pid"
logfile="${jenkins_qemu_node_agent_logfile}"
command_args="-P ${pidfile} -u ${service_user} -f -H -o ${logfile} -- ${app_command} ${app_args}"
extra_commands="reload"
sig_reload="HUP"

required_files="/etc/jenkins-qemu-node-agent/env"

start_precmd="${name}_prestart"
stop_postcmd="${name}_poststop"

jenkins_qemu_node_agent_prestart()
{
    logdir=$(dirname "${logfile}")

    install -d -o "${service_user}" -g "${service_user}" -m 0755 "${rundir}"
    install -d -m 0755 "${logdir}"
    if [ ! -f "${logfile}" ]; then
        install -o root -g "${service_user}" -m 0640 /dev/null "${logfile}"
    fi
    if [ -f "${pidfile}" ] && [ -z "$(check_pidfile "${pidfile}" "${procname}")" ]; then
        rm -f "${pidfile}"
    fi

    set -a
    . /etc/jenkins-qemu-node-agent/env
    set +a
}

jenkins_qemu_node_agent_poststop()
{
    if [ -f "${pidfile}" ] && [ -z "$(check_pidfile "${pidfile}" "${procname}")" ]; then
        rm -f "${pidfile}"
    fi
}

run_rc_command "$1"
