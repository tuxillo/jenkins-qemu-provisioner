JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
JENKINS_BOOTSTRAP_JOB_ENABLED=true
JENKINS_BOOTSTRAP_JOB_NAME=fake-ephemeral-test
JENKINS_BOOTSTRAP_JOB_LABEL=linux-kvm || dragonflybsd-nvmm
JENKINS_BOOTSTRAP_JOB_TIMEOUT_SEC=10
JENKINS_BOOTSTRAP_JOB_SLEEP_SEC=60
JENKINS_BOOTSTRAP_JOB_UPSERT=true
JENKINS_CONTROL_PLANE_UI_URL=http://localhost:8000/ui
JENKINS_AGENT_TCP_PORT=-1

# Control-plane Docker Compose settings
CP_JENKINS_URL=http://jenkins:8080
CP_JENKINS_USER=admin
CP_JENKINS_API_TOKEN=admin
CP_JENKINS_AGENT_TRANSPORT=websocket
CP_JENKINS_AGENT_TMPDIR=/var/tmp
CP_DATABASE_URL=sqlite:////data/control_plane.db
CP_DISABLE_BACKGROUND_LOOPS=false
CP_NODE_AGENT_URL=http://fake-node-agent:9000
CP_NODE_AGENT_AUTH_TOKEN=
CP_LABEL_POLICIES_FILE=/app/control_plane/label_policies.json
CP_IMAGE_CATALOG_FILE=/app/control_plane/image_catalog.json
CP_GUEST_IMAGE_COMPAT_MODE=false
CP_CONNECT_DEADLINE_SEC=180
CP_ALLOW_UNKNOWN_HOST_REGISTRATION=true

# Fake node-agent settings
FAKE_NODE_AGENT_HOST_ID=fake-host-1
FAKE_NODE_AGENT_CONTROL_PLANE_URL=http://control-plane:8000
FAKE_NODE_AGENT_BOOTSTRAP_TOKEN=fake-bootstrap-token
FAKE_NODE_AGENT_OS_FAMILY=linux
FAKE_NODE_AGENT_OS_VERSION=dev
FAKE_NODE_AGENT_SELECTED_ACCEL=kvm
FAKE_NODE_AGENT_SUPPORTED_ACCELS_CSV=kvm,tcg
FAKE_NODE_AGENT_ENABLE_HEARTBEAT_WORKER=true
FAKE_NODE_AGENT_HEARTBEAT_INTERVAL_SEC=5
FAKE_NODE_AGENT_CPU_TOTAL=8
FAKE_NODE_AGENT_RAM_TOTAL_MB=16384
FAKE_NODE_AGENT_IO_PRESSURE=0.0
FAKE_NODE_AGENT_AVAILABLE_IMAGES_JSON=[{"guest_image":"default","base_image_id":"default","source_digest":null,"cpu_arch":"x86_64","state":"READY"}]
